# Core
COMPOSE_PROJECT_NAME=aicompanion
TZ=UTC

# Ollama
OLLAMA_HOST=ollama
OLLAMA_PORT=11434
OLLAMA_DEFAULT_TEXT_MODEL=qwen2.5:14b
OLLAMA_FALLBACK_TEXT_MODEL=llama3.1:8b
OLLAMA_EXTRA_MODELS=

# Open WebUI
OPENWEBUI_PORT=3000
OPENWEBUI_SECRET_KEY=change-me-local-only

# Qdrant
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION=companion_memories
QDRANT_DISTANCE=Cosine
QDRANT_VECTOR_SIZE=768

# FastAPI bridge
FASTAPI_PORT=8080
FASTAPI_LOG_LEVEL=INFO
BRIDGE_SUMMARY_WINDOW=16
BRIDGE_RETRIEVAL_TOP_K=8

# ComfyUI
COMFYUI_HOST=comfyui
COMFYUI_PORT=8188
COMFYUI_OUTPUT_DIR=/data/images

# Companion Flask UI
COMPANION_UI_PORT=5050

# Safety policy: adults and consent only
ALLOW_FICTIONAL_ADULTS_ONLY=true
DISABLE_REAL_PERSON_WORKFLOWS=true

# Paths mounted into containers
DATA_ROOT=/data
CHARACTERS_DIR=/data/characters
MEMORIES_DIR=/data/memories
IMAGES_DIR=/data/images
MODELS_DIR=/data/models
LORAS_DIR=/data/loras
WORKFLOWS_DIR=/data/workflows
REFERENCE_PHOTOS_DIR=/data/reference_photos
LOGS_DIR=/data/logs
BACKUPS_DIR=/data/backups

# Optional auth token between Open WebUI and bridge (set in production)
WEBHOOK_SHARED_TOKEN=
